# QE.ai API service
FROM node:22-alpine AS base
WORKDIR /app
ENV NODE_ENV=production

COPY package.json package-lock.json* ./
COPY tsconfig.base.json ./
COPY packages/contracts/package.json packages/contracts/
COPY packages/agent-kernel/package.json packages/agent-kernel/
COPY packages/agents/package.json packages/agents/
COPY apps/api/package.json apps/api/
RUN npm install --omit=dev --ignore-scripts && npm install -w @qe-ai/api tsx typescript --no-save

COPY packages ./packages
COPY apps/api ./apps/api

EXPOSE 4000
USER node
HEALTHCHECK --interval=30s --timeout=5s CMD wget -qO- http://localhost:4000/health || exit 1
CMD ["npx", "tsx", "apps/api/src/main.ts"]
